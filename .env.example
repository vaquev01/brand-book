OPENAI_API_KEY=sk-...

# Optional: alternative image generation providers
STABILITY_API_KEY=
IDEOGRAM_API_KEY=

# Google AI: Gemini 2.0 Flash (text) + Imagen 3 (images)
# Get key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
