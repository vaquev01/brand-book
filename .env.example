# ============================================================
# brandbook-app — Environment Variables
# Copy to .env.local for local development
# On Railway: set in Variables tab of your service
# ============================================================

# ---- AI Generation (at least one required) ------------------
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=                 # Gemini + Imagen 3 (https://aistudio.google.com/app/apikey)
STABILITY_API_KEY=              # Stability AI (optional)
IDEOGRAM_API_KEY=               # Ideogram (optional)

# ---- Database -----------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/brandbook_app?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=brandbook_app

# ---- Authentication (NextAuth v5) ---------------------------
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3005

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Object Storage (Cloudflare R2 / S3-compatible) ---------
STORAGE_ENDPOINT=               # e.g. https://<account>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=brandbook-assets
STORAGE_PUBLIC_URL=             # CDN URL (optional, for public asset delivery)

# ---- Rate Limiting (Upstash Redis) --------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Stripe (mock — not yet implemented) --------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Runtime / Logging --------------------------------------
MAX_OLD_SPACE_SIZE=12288        # Node.js heap limit in MB (Railway)
BB_LOG_LEVEL=info               # debug | info | warn | error
BB_MEM_LOG_INTERVAL_MS=30000
# BB_MEM_LOG_DISABLED=1
