# Copy this file to .env.local for local development
# On Railway: set these in the Variables tab of your service

# Required for AI brandbook generation
OPENAI_API_KEY=sk-...

# Optional: alternative image generation providers
STABILITY_API_KEY=
IDEOGRAM_API_KEY=

# Google AI: Gemini 1.5 Flash (text) + Imagen 3 / Gemini Image Preview (images)
# Get key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Runtime memory tuning (Railway)
# Container RAM (e.g., 32GB) is different from Node heap limit.
# Increase this when seeing "JavaScript heap out of memory".
MAX_OLD_SPACE_SIZE=12288

# Structured logging / memory heartbeat
BB_LOG_LEVEL=info
BB_MEM_LOG_INTERVAL_MS=30000
# BB_MEM_LOG_DISABLED=1
